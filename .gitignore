# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/.terraform.lock.hcl
terraform/crash.log

# Ansible
*.retry
*.log
ansible/inventory/hosts.ini
ansible/.vault_pass

# Binaries and downloaded files
*.tar.gz
*.zip
*.iso
*.qcow2
*.pem
*.key
*.pub

# Local binary cache (LAN optimization mode) — directory is tracked, contents are not
cache/*
!cache/.gitkeep

# OS/Editor
.DS_Store
.idea/
.vscode/

# Local configuration overrides
config/settings.yml

# Molecule / Python
**/__pycache__/
**/.pytest_cache/
*.pyc
.venv/

