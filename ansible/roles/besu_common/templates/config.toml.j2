# Network
p2p-enabled=true
p2p-host="{{ besu_node_ip | default(ansible_host) }}"
p2p-port=30303

# RPC
rpc-http-enabled={{ 'true' if inventory_hostname in groups['rpc'] else 'false' }}
{% if inventory_hostname in groups['rpc'] %}
rpc-http-host="{{ besu_node_ip | default(ansible_host) }}"
rpc-http-port=8545
rpc-http-api=["ETH","NET","WEB3","QBFT","ADMIN"]
rpc-http-cors-origins=["*"]
rpc-http-tls-enabled=true
rpc-http-tls-keystore-file="/opt/besu/certs/keystore.p12"
rpc-http-tls-keystore-password-file="/opt/besu/certs/keystore.password"
{% endif %}

# WebSockets
rpc-ws-enabled={{ 'true' if inventory_hostname in groups['rpc'] else 'false' }}
{% if inventory_hostname in groups['rpc'] %}
rpc-ws-host="{{ besu_node_ip | default(ansible_host) }}"
rpc-ws-port=8546
rpc-ws-api=["ETH","NET","WEB3","QBFT","ADMIN"]
{% endif %}

# Consensus
genesis-file="/opt/besu/genesis.json"
data-path="/opt/besu/data"
host-allowlist=["*"]

# Metrics
metrics-enabled=true
metrics-host="{{ besu_node_ip | default(ansible_host) }}"
metrics-port={{ besu_metrics_port }}

# Bootnodes
bootnodes=[
{% for host in groups['bootnodes'] %}
  "enode://{{ lookup('file', '/tmp/besu-dist/' + host + '/key.pub') | trim | replace('0x', '') }}@{{ hostvars[host].besu_node_ip | default(hostvars[host].ansible_host | default(host)) }}:30303"{{ "," if not loop.last else "" }}
{% endfor %}
]
