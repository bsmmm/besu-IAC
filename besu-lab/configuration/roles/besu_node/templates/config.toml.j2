# Network
p2p-enabled=true
p2p-host="{{ ansible_host }}"
p2p-port=30303

# RPC
rpc-http-enabled=true
rpc-http-host="{{ ansible_host }}"
rpc-http-port=8545
rpc-http-api=["ETH","NET","WEB3","QBFT"]
rpc-http-cors-origins=["*"]
host-allowlist=["*"]
rpc-http-tls-enabled=true
rpc-http-tls-keystore-file="/opt/besu/certs/keystore.p12"
rpc-http-tls-keystore-password-file="/opt/besu/certs/keystore.password"

# WebSockets
rpc-ws-enabled=true
rpc-ws-host="{{ ansible_host }}"
rpc-ws-port=8546
rpc-ws-api=["ETH","NET","WEB3","QBFT"]

# Consensus
genesis-file="/opt/besu/genesis.json"
data-path="/opt/besu/data"

# Bootnodes (All 4 Validators)
bootnodes=[
{% for host in groups['validators'] %}
  "enode://{{ hostvars[host]['node_pubkey'] | replace('0x', '') }}@{{ hostvars[host]['ansible_host'] }}:30303"{{ "," if not loop.last else "" }}
{% endfor %}
]
