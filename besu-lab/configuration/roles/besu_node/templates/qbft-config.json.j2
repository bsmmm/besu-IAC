{
  "genesis": {
    "config": {
      "chainId": 1337,
      "qbft": {
        "blockperiodseconds": 2,
        "epochlength": 30000,
        "requesttimeoutseconds": 4
      }
    },
    "nonce": "0x0",
    "timestamp": "0x58ee40ba",
    "gasLimit": "0x1fffffffffffff",
    "difficulty": "0x1",
    "alloc": {}
  },
  "blockchain": {
    "nodes": {
      "generate": false,
      "keys": [
{% for host in groups['validators'] %}
        {
          "address": "{{ hostvars[host]['validator_address'] }}"
        }{{ "," if not loop.last else "" }}
{% endfor %}
      ]
    }
  }
}
